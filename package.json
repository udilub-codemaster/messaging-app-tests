{
  "name": "messaging-app-tests",
  "version": "1.0.0",
  "description": "Playwright tests for CommBox messaging app",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:sanity": "npx playwright test --project=sanity",
    "test:full-regression": "npx playwright test --project=full-regression",
    "report:playwright": "npx playwright show-report",
    "report:allure": "npx allure generate allure-results -o allure-report --clean && npx allure open allure-report"
  },
