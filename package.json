  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.4.0",
    "allure-commandline": "^2.37.0",
    "allure-playwright": "^3.6.0"
  }
}
